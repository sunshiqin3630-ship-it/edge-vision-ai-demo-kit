# Sanitized board build and runtime settings.
# Replace placeholder paths on your local machine. Do not commit private SDKs,
# credentials, lab-only hosts, copied runtime bundles, or generated model files.

BOARD_ARCH=aarch64
BOARD_QT_MAJOR=auto
BOARD_SYSROOT=/path/to/board/sysroot
BOARD_QT_CMAKE_PREFIX=/path/to/board/sysroot/usr/lib/cmake
BOARD_TOOLCHAIN_PREFIX=aarch64-linux-gnu-

# Common Qt platform choices on embedded Linux: eglfs, linuxfb, wayland, xcb.
QT_QPA_PLATFORM=eglfs

# Sanitized screen resource placeholders.
EDGE_VIEWER_PRIMARY_CONNECTOR=HDMI-A-1
EDGE_VIEWER_SECONDARY_CONNECTOR=DSI-1
EDGE_VIEWER_PRIMARY_GEOMETRY=1920x1080+0+0
EDGE_VIEWER_SECONDARY_GEOMETRY=1280x720+1920+0

# Public capture examples. Replace locally without committing private values.
EDGE_VIEWER_SOURCE_TYPE=synthetic
EDGE_VIEWER_FFMPEG_URL=rtsp://example-camera.local/live
EDGE_VIEWER_V4L2_DEVICE=/dev/video0
