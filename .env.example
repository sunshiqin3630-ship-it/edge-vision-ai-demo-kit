# Copy to .env and adapt locally. Do not commit .env.

EDGE_VISION_BACKEND=mock
EDGE_VISION_SOURCE=sample://frame
EDGE_VISION_MODEL=yolo11n-detect
EDGE_VISION_FRAME_WIDTH=1280
EDGE_VISION_FRAME_HEIGHT=720

# Optional private backend settings. Keep real paths and credentials local.
EDGE_VISION_ACCELERATOR_SDK_ROOT=/path/to/private/sdk
EDGE_VISION_BOARD_HOST=example-board.local
EDGE_VISION_BOARD_USER=developer
